/ {
    behaviors {
        // Behavior can be invoked on peripherals, so name must be <= 8 characters.
        rgb_ext: rgb_ext {
            compatible = "zmk,behavior-rgb-ext";
            #binding-cells = <2>;
            display-name = "RGB Extended";
        };
    };
};